datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id               String            @id @default(cuid())
  name             String
  accountSize      Decimal
  createdAt        DateTime          @default(now())
  balanceSnapshots BalanceSnapshot[]
  trades           Trade[]
}

model BalanceSnapshot {
  id              String   @id @default(cuid())
  account         Account  @relation(fields: [accountId], references: [id])
  accountId       String
  snapshotBalance Decimal
  effectiveDate   DateTime @default(now())

  @@index([accountId])
}

model Trade {
  id             String   @id @default(cuid())
  account        Account  @relation(fields: [accountId], references: [id])
  accountId      String
  entryDate      DateTime
  exitDate       DateTime
  pnl            Decimal
  stopLossSize   Decimal
  riskPercentage Decimal
  symbol         String?
  side           String?
  notes          String?
  createdAt      DateTime @default(now())

  @@index([accountId])
}
